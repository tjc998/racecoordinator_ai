{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "outDir": "./dist/out-tsc",
    "types": [
      "jasmine",
      "node"
    ]
  },
  "files": [
    "src/test.ts"
  ],
  "include": [
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "src/**/*_test.ts",
    "src/**/*.mock.ts",
    "src/**/*.harness.ts",
    "src/**/*.e2e.ts",
    "src/**/*_helper.ts",
    "src/**/*.d.ts",
    "playwright.config.ts"
  ]
}