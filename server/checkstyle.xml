<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
          "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
          "https://checkstyle.org/dtds/configuration_1_3.dtd">
<module name="Checker">
    <module name="TreeWalker">
        <module name="UnusedImports"/>
        <module name="RedundantImport"/>
        <!-- Fallback for UnnecessaryFullyQualifiedName which fails to instantiate -->
        <module name="RegexpSinglelineJava">
            <property name="format" value="^(?!.*// fqn-collision)(?!.*import)(?!.*package).*\bcom\.antigravity\.(?:[a-z0-9]+\.)*[A-Z]"/>
            <property name="ignoreComments" value="false"/>
            <property name="message" value="Do not use fully qualified names for internal classes. Use imports instead. If this is required for a name collision, add '// fqn-collision' to the line."/>
        </module>
    </module>
</module>
